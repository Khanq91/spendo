<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spendo"
        android:textSize="12sp"
        android:textColor="#F06292"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:layout_gravity="center">

        <LinearLayout
            android:id="@+id/btn_cat_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_cat_bg"
            android:layout_margin="4dp">
            <TextView android:id="@+id/tv_cat_0_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍜"
                android:textSize="20sp"/>
            <TextView android:id="@+id/tv_cat_0_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ăn uống"
                android:textSize="10sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_cat_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_cat_bg"
            android:layout_margin="4dp">
            <TextView android:id="@+id/tv_cat_1_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗"
                android:textSize="20sp"/>
            <TextView android:id="@+id/tv_cat_1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Di chuyển"
                android:textSize="10sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_cat_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_cat_bg"
            android:layout_margin="4dp">
            <TextView android:id="@+id/tv_cat_2_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍️"
                android:textSize="20sp"/>
            <TextView android:id="@+id/tv_cat_2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mua sắm"
                android:textSize="10sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_cat_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_cat_bg"
            android:layout_margin="4dp">
            <TextView android:id="@+id/tv_cat_3_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚"
                android:textSize="20sp"/>
            <TextView android:id="@+id/tv_cat_3_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Học tập"
                android:textSize="10sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </GridLayout>
</LinearLayout>